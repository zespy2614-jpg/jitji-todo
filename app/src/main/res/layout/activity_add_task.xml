<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/inputCard"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:layout_marginHorizontal="6dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_input">

        <EditText
            android:id="@+id/editInput"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@null"
            android:paddingStart="12dp"
            android:paddingEnd="8dp"
            android:hint="@string/input_hint"
            android:textColor="@color/input_text"
            android:textColorHint="@color/input_hint"
            android:textSize="12sp"
            android:inputType="textCapSentences"
            android:imeOptions="actionDone"
            android:maxLines="1"
            android:singleLine="true"
            android:importantForAutofill="no"
            tools:ignore="LabelFor" />

        <FrameLayout
            android:id="@+id/buttonAdd"
            android:layout_width="52dp"
            android:layout_height="match_parent"
            android:background="@drawable/bg_send_selector"
            android:clickable="true"
            android:focusable="true"
            android:enabled="false">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_check"
                android:contentDescription="@string/add_task" />
        </FrameLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp">

        <TextView
            android:id="@+id/textDue"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/no_reminder"
            android:textColor="@color/muted"
            android:textSize="11sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonPickDue"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/pick_due"
            android:textColor="@color/white"
            android:textSize="11sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonClearDue"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/clear"
            android:textColor="@color/muted"
            android:textSize="11sp"
            android:visibility="gone" />
    </LinearLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/quickAlarmBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingBottom="8dp" />
    </HorizontalScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />
</LinearLayout>
